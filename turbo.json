{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["build/**"]
    },
    "npm:publish": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "^npm:publish"]
    }
  }
}
